html
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
  body(
    style='margin: 0; padding: 0; background-color: #fdfaf9; font-family: Arial, sans-serif'
  )
    include header.pug

    table(
      width='100%',
      cellpadding='0',
      cellspacing='0',
      border='0',
      style='padding: 20px 0'
    )
      tr
        td(align='center')
          table(
            width='600',
            cellpadding='0',
            cellspacing='0',
            border='0',
            style='border-radius: 8px; overflow: hidden; background-color: #ffffff'
          )

            // Greeting + intro (combined, no wasted row)
            tr
              td(style='padding: 30px 30px 0 30px')
                if firstName
                  p(
                    style='color: #333; font-size: 16px; margin: 0 0 16px 0'
                  ) Hi #{ firstName },
                p(
                  style='color: #113a5d; font-size: 20px; font-weight: bold; margin: 0 0 12px 0; line-height: 1.3'
                ) What's one thing that went well this week?
                p(
                  style='color: #555; font-size: 15px; margin: 0; line-height: 1.6'
                ) It doesn't have to be big. Logging it takes 2 minutes — and over time, those entries become the evidence you reach for in reviews, interviews, and negotiations.


            // Prompt starters
            tr
              td(style='padding: 20px 30px 0 30px')
                p(
                  style='color: #333; font-size: 14px; font-weight: bold; margin: 0 0 8px 0'
                ) Not sure where to start? Pick one:
                ul(
                  style='color: #555; font-size: 14px; padding-left: 20px; margin: 0; line-height: 1.8'
                )
                  li Something you fixed, shipped, or unblocked
                  li A moment someone noticed your work
                  li A skill you stretched or leaned on

            // Streak / stats callout — shown only when data exists
            if (streakCount && streakCount > 0) || (totalAchievements && totalAchievements > 0)
              tr
                td(style='padding: 20px 30px 0 30px')
                  table(
                    width='100%',
                    cellpadding='0',
                    cellspacing='0',
                    border='0',
                    style='background-color: #fff5f6; border-radius: 8px; border-left: 4px solid #ff7a8a'
                  )
                    tr
                      td(style='padding: 16px 20px')
                        if streakCount && streakCount > 0
                          p(
                            style='color: #113a5d; font-size: 15px; font-weight: bold; margin: 0 0 4px 0'
                          )  #{streakCount}-week streak
                          p(
                            style='color: #555; font-size: 13px; margin: 0'
                          ) Keep it going — one more entry and this week counts.
                        if totalAchievements && totalAchievements > 0
                          p(
                            style='color: #113a5d; font-size: 15px; font-weight: bold; margin: #{streakCount && streakCount > 0 ? "12px" : "0"} 0 4px 0'
                          ) #{totalAchievements} achievements logged
                          p(
                            style='color: #555; font-size: 13px; margin: 0'
                          ) Every one of those is a story you own.
            else
              tr
                td(style='padding: 20px 30px 0 30px')
                  table(
                    width='100%',
                    cellpadding='0',
                    cellspacing='0',
                    border='0',
                    style='background-color: #f0faf8; border-radius: 8px; border-left: 4px solid #00bfa6'
                  )
                    tr
                      td(style='padding: 16px 20px')
                        p(
                          style='color: #113a5d; font-size: 15px; font-weight: bold; margin: 0 0 4px 0'
                        ) Start your streak this week
                        p(
                          style='color: #555; font-size: 13px; margin: 0'
                        ) One entry a week adds up fast. A year from now, you'll have 50 wins documented.

            // CTA
            tr
              td(style='padding: 28px 30px 32px 30px; text-align: center')
                a(
                  href=weeklyLink,
                  style='background-color: #ff7a8a; color: #000000; text-decoration: none; padding: 14px 32px; border-radius: 6px; display: inline-block; font-weight: bold; font-size: 15px;'
                ) Log this week's win
                 p(
                  style='color: #000000; font-size: 12px; margin: 10px 0 0 0;'
                ) This link expires in 24 hours.

    include footer.pug
